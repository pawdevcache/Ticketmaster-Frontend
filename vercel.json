{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "https://ticketmaster-backend-eight.vercel.app/api/$1" },
    { "source": "/discovery/(.*)", "destination": "https://ticketmaster-backend-eight.vercel.app/discovery/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
