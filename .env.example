# Public origin of the Go backend. Leave EMPTY for local dev — Vite's proxy
# (vite.config.js) forwards /api and /discovery to http://localhost:8080.
#
# For a Vercel deploy, set this in Project Settings -> Environment Variables
# to your publicly hosted backend, e.g.
# VITE_API_URL=https://ticketmaster-api.onrender.com
VITE_API_URL=https://ticketmaster-backend-alpha.vercel.app/
